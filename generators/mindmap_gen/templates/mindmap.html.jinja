<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>
    html, body {
      margin: 0; padding: 0; height: 100%;
      background: #0f172a;
      color: #f1f5f9;
      font-family: system-ui, -apple-system, sans-serif;
      overflow: hidden;
    }
    .header {
      padding: 10px 18px;
      border-bottom: 1px solid #1e293b;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #0d1526;
    }
    .header h1 {
      margin: 0;
      font-size: 14px;
      font-weight: 500;
      color: #f1f5f9;
    }
    .header button {
      background: #1e293b;
      color: #cbd5e1;
      border: 1px solid #334155;
      padding: 5px 12px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
    }
    .header button:hover { background: #334155; color: #f1f5f9; }
    #mm { width: 100vw; height: calc(100vh - 45px); display: block; }
    .markmap-link{fill:none!important}
    .markmap-node{color:var(--branch-color,#cbd5e1)!important}
    .markmap-node>line,
    .markmap-node>circle{stroke:currentColor!important}
    .markmap-foreign,
    .markmap-foreign *{
      color:inherit!important;
      border-color:currentColor!important;
      text-decoration-color:currentColor!important;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>{{ title }}</h1>
    <div style="display:flex;gap:8px;">
      <button id="download-svg">Download SVG</button>
      <button id="download-png">Download PNG</button>
    </div>
  </div>
  <svg id="mm"></svg>
  <div id="error" style="display:none;padding:14px 18px;color:#fca5a5;font-size:13px;"></div>
  <script type="module">
    import { Transformer } from "https://cdn.jsdelivr.net/npm/markmap-lib@0.18/+esm";
    import { Markmap } from "https://cdn.jsdelivr.net/npm/markmap-view@0.18/+esm";

    const markdown = {{ markdown | tojson }};
    const BRANCH_COLORS = [
      "#60a5fa","#4ade80","#f472b6","#fb923c",
      "#a78bfa","#38bdf8","#34d399","#facc15",
      "#e879f9","#2dd4bf","#f87171","#c084fc"
    ];
    const ROOT_COLOR = "#cbd5e1";

    const svg = document.querySelector('#mm');
    const errEl = document.querySelector('#error');

    function collapseInitialTree(node, depth = 0) {
      if (!node?.children?.length) return;
      node.payload = { ...(node.payload ?? {}) };
      if (depth === 0) {
        delete node.payload.fold;
      } else {
        node.payload.fold = 1;
      }
      for (const child of node.children) {
        collapseInitialTree(child, depth + 1);
      }
    }

    function fitMindmap(mm) {
      try {
        mm.fit?.();
      } catch {
        // ignore
      }
    }

    function applyVisibleBranchColors() {
      const branchNodes = Array.from(
        svg.querySelectorAll('g.markmap-node[data-depth="2"]'),
      );
      const colorByBranchPath = new Map();
      branchNodes.forEach((node, index) => {
        const path = node.getAttribute('data-path');
        if (path) {
          colorByBranchPath.set(path, BRANCH_COLORS[index % BRANCH_COLORS.length]);
        }
      });

      function resolveColor(path, depth) {
        if (!path || depth === '1') return ROOT_COLOR;
        const branchPath = path.split('.').slice(0, 2).join('.');
        return (
          colorByBranchPath.get(branchPath) ||
          BRANCH_COLORS[fallbackColorIndex(branchPath) % BRANCH_COLORS.length]
        );
      }

      for (const node of Array.from(svg.querySelectorAll('g.markmap-node'))) {
        const color = resolveColor(
          node.getAttribute('data-path'),
          node.getAttribute('data-depth'),
        );
        node.style.setProperty('--branch-color', color);
        node.style.setProperty('color', color, 'important');
        for (const labelPart of Array.from(
          node.querySelectorAll('foreignObject, foreignObject *'),
        )) {
          labelPart.style.setProperty('color', color, 'important');
          labelPart.style.setProperty('border-color', color, 'important');
          labelPart.style.setProperty('text-decoration-color', color, 'important');
        }
        node.querySelector('text')?.style.setProperty('fill', color, 'important');
        for (const svgPart of Array.from(
          node.querySelectorAll('circle,path,line,polyline'),
        )) {
          svgPart.setAttribute('stroke', color);
          svgPart.style.setProperty('stroke', color, 'important');
          if (svgPart.tagName.toLowerCase() === 'circle') {
            svgPart.setAttribute('fill', color);
            svgPart.style.setProperty('fill', color, 'important');
          }
        }
      }

      for (const link of Array.from(svg.querySelectorAll('path.markmap-link'))) {
        const color = resolveColor(
          link.getAttribute('data-path'),
          link.getAttribute('data-depth'),
        );
        link.setAttribute('stroke', color);
        link.setAttribute('fill', 'none');
        link.style.setProperty('stroke', color, 'important');
        link.style.setProperty('fill', 'none', 'important');
      }
    }

    function refreshMindmapView(mm, delay = 80) {
      window.setTimeout(() => {
        fitMindmap(mm);
        applyVisibleBranchColors();
        window.setTimeout(() => applyVisibleBranchColors(), 420);
      }, delay);
    }

    function fallbackColorIndex(value) {
      let hash = 0;
      for (let index = 0; index < value.length; index += 1) {
        hash = (hash * 31 + value.charCodeAt(index)) >>> 0;
      }
      return hash;
    }

    function branchColor(node) {
      let branch = node;
      while (branch?.parent?.parent) {
        branch = branch.parent;
      }
      if (!branch?.parent) return ROOT_COLOR;

      const siblings = Array.isArray(branch.parent.children) ? branch.parent.children : [];
      const siblingIndex = siblings.indexOf(branch);
      const colorIndex = siblingIndex >= 0
        ? siblingIndex
        : fallbackColorIndex(String(branch?.state?.path ?? branch?.content ?? ""));
      return BRANCH_COLORS[colorIndex % BRANCH_COLORS.length];
    }

    try {
      const transformer = new Transformer();
      const { root } = transformer.transform(markdown);
      collapseInitialTree(root);

      const mm = Markmap.create(svg, {
        duration: 400,
        maxWidth: 300,
        spacingHorizontal: 110,
        spacingVertical: 12,
        paddingX: 16,
        autoFit: true,
        style: () => `.markmap {
          --markmap-text-color: #f1f5f9;
          --markmap-circle-open-bg: #1e293b;
          --markmap-font: 400 13px/1.5 system-ui, sans-serif;
        }`,
        color: branchColor,
      }, root);
      refreshMindmapView(mm);
      svg.addEventListener('click', () => refreshMindmapView(mm, 450), true);
    } catch (err) {
      svg.style.display = 'none';
      errEl.style.display = 'block';
      errEl.textContent = "Couldn't render mind map: " + (err?.message ?? err);
      console.error(err);
    }

    // Build a self-contained <svg> string with the current rendered size
    // baked in. Used by both the SVG and PNG download paths.
    function serializeSvg() {
      const rect = svg.getBoundingClientRect();
      const width = Math.max(1, Math.ceil(rect.width));
      const height = Math.max(1, Math.ceil(rect.height));
      const clone = svg.cloneNode(true);
      clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
      clone.setAttribute('xmlns:xhtml', 'http://www.w3.org/1999/xhtml');
      clone.setAttribute('width', String(width));
      clone.setAttribute('height', String(height));
      return {
        width,
        height,
        text: new XMLSerializer().serializeToString(clone),
      };
    }

    function triggerDownload(blob, filename) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    }

    document.querySelector('#download-svg').addEventListener('click', () => {
      const { text } = serializeSvg();
      triggerDownload(
        new Blob([text], { type: 'image/svg+xml' }),
        '{{ filename }}.svg',
      );
    });

    document.querySelector('#download-png').addEventListener('click', async () => {
      const btn = document.querySelector('#download-png');
      const originalLabel = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Rendering…';
      try {
        const { width, height, text } = serializeSvg();
        // Encode unicode → base64 safely (markmap text may contain non-ASCII).
        const b64 = btoa(unescape(encodeURIComponent(text)));
        const dataUrl = 'data:image/svg+xml;charset=utf-8;base64,' + b64;

        const img = new Image();
        await new Promise((resolve, reject) => {
          img.onload = resolve;
          img.onerror = () => reject(new Error('failed to rasterize SVG'));
          img.src = dataUrl;
        });

        const scale = window.devicePixelRatio > 1 ? window.devicePixelRatio : 2;
        const canvas = document.createElement('canvas');
        canvas.width = width * scale;
        canvas.height = height * scale;
        const ctx = canvas.getContext('2d');
        ctx.scale(scale, scale);
        // Fill the dark theme background so PNG isn't transparent.
        ctx.fillStyle = '#0f172a';
        ctx.fillRect(0, 0, width, height);
        ctx.drawImage(img, 0, 0, width, height);

        const blob = await new Promise((resolve, reject) => {
          canvas.toBlob(
            (b) => (b ? resolve(b) : reject(new Error('canvas.toBlob returned null'))),
            'image/png',
          );
        });
        triggerDownload(blob, '{{ filename }}.png');
      } catch (err) {
        console.error(err);
        alert("Couldn't export PNG: " + (err?.message ?? err));
      } finally {
        btn.disabled = false;
        btn.textContent = originalLabel;
      }
    });
  </script>
</body>
</html>
