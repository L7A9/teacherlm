{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TeacherLM",
  "version": "0.1.0",
  "identifier": "local.teacherlm.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm.cmd run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../apps/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TeacherLM",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"]
  }
}

