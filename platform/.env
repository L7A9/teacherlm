# Copy this file to `.env` and fill in real values before running docker-compose.
# Anything left blank uses the default in parentheses.

# ---------- Postgres ----------
POSTGRES_USER=teacherlm
POSTGRES_PASSWORD=teacherlm
POSTGRES_DB=teacherlm
POSTGRES_PORT=5432

# Overridden inside the compose network; used only when running backend on the host.
DATABASE_URL=postgresql+asyncpg://teacherlm:teacherlm@localhost:5432/teacherlm

# ---------- Redis (arq) ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------- Qdrant ----------
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---------- MinIO ----------
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=teacherlm
MINIO_SECURE=false

# ---------- LlamaCloud (llama-cloud >= 1.0 — NEVER llama-parse / llama-cloud-services) ----------
LLAMA_CLOUD_API_KEY=llx-LoMuHe1sCM8LPcINISTGpypzgbNRaXobmmfICllK4Qev5urs
LLAMA_CLOUD_BASE_URL=https://api.cloud.llamaindex.ai

# ---------- Ollama ----------
# Host-reachable URL. Inside docker-compose the backend rewrites this to
# http://host.docker.internal:11434 so the container can reach Ollama on the host.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=gemma4:e2b
MINDMAP_GEN_MODEL=gemma4:e4b

# ---------- RAG / Retrieval ----------
# For multilingual courses, use a multilingual embedding model. BAAI/bge-m3 is
# not supported by the current FastEmbed version, so this local-compatible
# default uses E5-large. When changing the model/dimension, re-ingest courses.
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=8
# Downloads the embedding model during backend/arq_worker image build so first
# upload/search does not wait on Hugging Face. Set false for tiny/offline builds.
PREFETCH_EMBEDDING_MODEL=true
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=50
RETRIEVAL_TOP_K=8
RETRIEVAL_DENSE_CANDIDATE_K=80
RETRIEVAL_SPARSE_CANDIDATE_K=80
RETRIEVAL_CONTEXT_EXPANSION_ENABLED=true
RETRIEVAL_NEIGHBOR_WINDOW=1
RETRIEVAL_PARENT_MAX_TOKENS=900
RETRIEVAL_EXPANSION_MAX_CHARS=4500
# Enabled in the backend so every generator receives already-reranked chunks.
RETRIEVAL_RERANK_ENABLED=true
RETRIEVAL_RERANK_WARMUP_ENABLED=true
RETRIEVAL_RERANKER_MODEL=BAAI/bge-reranker-base
PREFETCH_RERANKER_MODEL=true
RETRIEVAL_RERANK_CANDIDATE_K=50
RETRIEVAL_RERANK_TOP_K=8
RETRIEVAL_RERANK_MODES='["semantic_topk","coverage_broad","narrative_arc","topic_clusters","relationship_dense"]'

# Keep ingestion serial by default. The large multilingual embedder can exhaust
# memory when several uploaded files embed in parallel.
INGESTION_MAX_JOBS=1
INGESTION_JOB_TIMEOUT_S=3600

# ---------- Ports exposed by compose ----------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
