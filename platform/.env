# Copy this file to `.env` and fill in real values before running docker-compose.
# Anything left blank uses the default in parentheses.

# ---------- Postgres ----------
POSTGRES_USER=teacherlm
POSTGRES_PASSWORD=teacherlm
POSTGRES_DB=teacherlm
POSTGRES_PORT=5432

# Overridden inside the compose network; used only when running backend on the host.
DATABASE_URL=postgresql+asyncpg://teacherlm:teacherlm@localhost:5432/teacherlm

# ---------- Redis (arq) ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------- Qdrant ----------
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---------- MinIO ----------
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=teacherlm
MINIO_SECURE=false

# ---------- LlamaCloud (llama-cloud >= 1.0 — NEVER llama-parse / llama-cloud-services) ----------
LLAMA_CLOUD_API_KEY=llx-LoMuHe1sCM8LPcINISTGpypzgbNRaXobmmfICllK4Qev5urs
LLAMA_CLOUD_BASE_URL=https://api.cloud.llamaindex.ai

# ---------- Ollama ----------
# Host-reachable URL. Inside docker-compose the backend rewrites this to
# http://host.docker.internal:11434 so the container can reach Ollama on the host.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.1:8b

# ---------- Model overrides (point every generator at llama3.1:8b) ----------
# The compose defaults reference llama3.1:8b-instruct-q4_K_M and
# llama3.2:latest, neither of which is pulled locally. Override them
# here so every generator hits a model that actually exists. To go back
# to the original mix, delete this block and `ollama pull` the
# original names listed in docker-compose.yml.
TEACHER_GEN_CHAT_MODEL=llama3.1:8b
TEACHER_GEN_ANALYSIS_MODEL=llama3.1:8b
TEACHER_GEN_EXTRACTION_MODEL=llama3.1:8b
QUIZ_GEN_CHAT_MODEL=llama3.1:8b
QUIZ_GEN_EXTRACTION_MODEL=llama3.1:8b
QUIZ_GEN_GENERATION_MODEL=llama3.1:8b
MINDMAP_GEN_MODEL=llama3.1:8b
PODCAST_GEN_CHAT_MODEL=llama3.1:8b
PODCAST_GEN_EXTRACTION_MODEL=llama3.1:8b
PODCAST_GEN_GENERATION_MODEL=llama3.1:8b

# ---------- Ports exposed by compose ----------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000


# cd generators/teacher_gen
# claude --resume c9f90f52-6ee5-4c5d-a96a-e40b0997bd05
